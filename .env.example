# Site URL for SEO (metadataBase, canonical, sitemap)
NEXT_PUBLIC_SITE_URL=https://rodshub.com

# R2 图片根 URL：产品图直接从 Cloudflare R2 拉取
# 自定义域名：https://images.rodshub.com（需在 R2 桶的 Custom Domains 中绑定）
# 或 r2.dev：https://pub-xxxx.r2.dev（在 R2 桶设置中启用 Public Development URL 后可见）
# 路径格式：{base}/{sku}/{file}，如 BDG01/1.jpg
NEXT_PUBLIC_R2_IMAGE_BASE=https://images.rodshub.com

# R2 类目图桶（rodshub-categories）公共访问根 URL
# 桶内文件：Spinning Rods.png, Casting Rods.png, Telescopic Rods.png, Surf Rods.png, Ice Fishing Rods.png, Travel Rods.png
# 已绑定自定义域名 categories.rodshub.com
NEXT_PUBLIC_R2_CATEGORIES_BASE=https://categories.rodshub.com
